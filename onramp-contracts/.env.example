# ============================================================
# ONRAMP BOB→USDT — Variables de Entorno
# ============================================================
# NUNCA commitear este archivo a git. Agregar .env a .gitignore.

# --- RPC URLs ---
# Polygon Amoy testnet (gratis: https://faucet.polygon.technology)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygon Mainnet
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# --- Private Keys (NUNCA exponer) ---
# Private key del deployer (para deploy del contrato)
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Private key del OPERATOR (backend firma releases)
OPERATOR_PRIVATE_KEY=0x_YOUR_OPERATOR_KEY_HERE

# Private key del LP_ADMIN (depósitos/retiros)
LP_PRIVATE_KEY=0x_YOUR_LP_PRIVATE_KEY_HERE

# --- Block Explorer API ---
# Polygonscan: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# --- Addresses (se llenan después del deploy) ---
# Dirección del contrato EscrowMaster desplegado
ESCROW_MASTER_ADDRESS=

# Dirección del token USDT en Polygon
# Mainnet: 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# Amoy testnet: usar un mock ERC20 para testing
USDT_ADDRESS=
