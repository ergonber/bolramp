# =============================================================================
# ONRAMP BOB→USDT — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------

# Server environment: development | production | test
NODE_ENV=development

# Port for the Express server
PORT=3001

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/onramp

# Redis URL (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain / Smart Contract
# -----------------------------------------------------------------------------

# Private key for the OPERATOR role (signs EIP-712 releases)
# WARNING: Never share this key. Use a dedicated wallet for operations.
# Can be obtained from MetaMask > Account Details > Export Private Key
OPERATOR_PRIVATE_KEY=your_64_character_hex_private_key_here

# Address of the deployed EscrowMaster contract on Polygon
# After deployment, verify on Polygonscan
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon RPC URL
# Free: https://polygon-rpc.com or https://rpc.ankr.com/polygon
# Paid (recommended for production): Alchemy, Infura, QuickNode
POLYGON_RPC_URL=https://polygon-rpc.com

# Chain ID: 137 (Polygon Mainnet) or 80002 (Polygon Amoy Testnet)
CHAIN_ID=137

# -----------------------------------------------------------------------------
# OpenBCB (Bolivian Payment Gateway)
# -----------------------------------------------------------------------------

# OpenBCB API key — get from https://openbcb.io
OPENBCB_API_KEY=your_openbcb_api_key

# OpenBCB API base URL
OPENBCB_API_URL=https://api.openbcb.io/v1

# OpenBCB webhook HMAC secret for signature verification
# Get from OpenBCB dashboard > Webhooks > Secret
OPENBCB_WEBHOOK_SECRET=your_webhook_hmac_secret

# -----------------------------------------------------------------------------
# Pricing
# -----------------------------------------------------------------------------

# LP spread in basis points (50 = 0.5%)
LP_SPREAD_BPS=50

# Platform fee in basis points (50 = 0.5%)
PLATFORM_FEE_BPS=50

# Quote expiry in seconds (how long a quote is valid)
QUOTE_EXPIRY_SECONDS=120

# Trade expiry in seconds (how long a trade stays locked)
TRADE_EXPIRY_SECONDS=300

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# API key for backend authentication (frontend sends this in x-api-key header)
API_KEY=your_random_api_key_here

# JWT secret for token authentication (min 32 characters)
JWT_SECRET=change_this_to_a_random_32_char_string

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn

# -----------------------------------------------------------------------------
# Frontend (NEXT_PUBLIC_ vars are exposed to the browser)
# -----------------------------------------------------------------------------

# Backend API URL (used by frontend to call backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# API key for frontend (sent in x-api-key header)
NEXT_PUBLIC_API_KEY=your_api_key_here

# Chain ID for wallet connection
NEXT_PUBLIC_CHAIN_ID=137

# WalletConnect Project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Escrow contract address (for frontend display)
NEXT_PUBLIC_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# USDC contract address on Polygon (Amoy testnet)
# Polygon Amoy: 0x41e94eb019c0762f9bfcf9fb1e58725bfb0e7582
# Polygon Mainnet USDT: 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
NEXT_PUBLIC_USDC_ADDRESS=0x41e94eb019c0762f9bfcf9fb1e58725bfb0e7582
